{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qaz.fund/schemas/ranking-review-v1.schema.json",
  "title": "QAZ.FUND ranking review row v1",
  "type": "object",
  "required": [
    "schema_version",
    "item_id",
    "title",
    "source",
    "source_url",
    "ranking",
    "relevance_label",
    "action_priority_label",
    "reviewer",
    "reviewed_at"
  ],
  "properties": {
    "schema_version": {
      "const": "qazfund-ranking-review-v1"
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "string"
    },
    "deadline": {
      "type": ["string", "null"],
      "format": "date"
    },
    "ranking": {
      "type": "object",
      "required": [
        "model_version",
        "relevance",
        "priority",
        "geography",
        "confidence"
      ],
      "properties": {
        "model_version": {
          "type": "string",
          "minLength": 1
        },
        "relevance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "geography": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "relevance_label": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 3
    },
    "action_priority_label": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 3
    },
    "reviewer": {
      "type": ["string", "null"]
    },
    "reviewed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "relevance_label": {
                "type": "integer"
              }
            }
          },
          {
            "properties": {
              "action_priority_label": {
                "type": "integer"
              }
            }
          }
        ]
      },
      "then": {
        "properties": {
          "reviewer": {
            "type": "string",
            "minLength": 1
          },
          "reviewed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
