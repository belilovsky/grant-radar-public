# Copy to .env and fill in real values. NEVER commit secrets.

POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+psycopg://grantradar:changeme@db:5432/grantradar
# Repository backend for grant-radar (used by core.repository_factory.make_repository)
# Leave empty / set to "memory" to use in-process InMemoryRepository (tests/dev).
# Use sqlite:///./data/grants.db for local file persistence,
# or postgresql+psycopg://... to share with DATABASE_URL above.
GRANT_RADAR_DB_URL=sqlite:///./data/grants.db
# Public origin used for canonical links and share pages.
PUBLIC_BASE_URL=http://localhost:8000
ROOT_PATH=
REDIS_URL=redis://redis:6379/0
GRANT_RADAR_ADMIN_TOKEN=

# Telegram digest
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Sheets (optional)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp.json
GSHEET_ID=

# Misc
LOG_LEVEL=INFO
TZ=Asia/Almaty

# Worker
GRANT_RADAR_SOURCES=grants_gov,astana_hub,internews,isdb_project_procurement,ebrd_ecepp_procurement,erasmus_kazakhstan,opportunity_desk,fundsforngos,kazakhstan_watch,eeas_kazakhstan,world_bank_kazakhstan,adb_kazakhstan,google_cloud_startup,microsoft_founders_hub,aws_activate,nvidia_inception,cloudflare_startups,mongodb_startups,unicef_kazakhstan,google_org_ai_opportunity,unesco_iite,undp_procurement
GRANT_RADAR_SOURCE_INTERVAL_SECONDS=21600
GRANT_RADAR_MIGRATION_ATTEMPTS=30
GRANT_RADAR_MIGRATION_SLEEP_SECONDS=2
